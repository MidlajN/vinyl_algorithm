{
  "name": "vinyl-wasm",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5175",
    "build": "tsc && vite build",
    "preview": "vite preview --port 5175",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup:opencv": "cp node_modules/@techstark/opencv-js/dist/opencv.js public/opencv.js",
    "postinstall": "npm run setup:opencv"
  },
  "devDependencies": {
    "@techstark/opencv-js": "^4.10.0-release.1",
    "typescript": "~5.7.0",
    "vite": "^6.3.0",
    "vitest": "^3.2.0"
  }
}
